// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// Continue after the 5th point for setting up the db

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String   @id @default(uuid()) // user_id
  email        String   @unique
  username     String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relációk
  connectedApps          ConnectedApp[]
  posts                  Post[]
  comments               Comment[]
  commentLikes           CommentLike[]
  notifications          Notification[] @relation("UserNotifications")
  triggeredNotifications Notification[] @relation("TriggeredNotifications")
  moderationLogs         ModerationLog[]
}

model ConnectedApp {
  id          String   @id @default(uuid()) // internal id
  platform     String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  connectedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  userId      String

  @@unique([userId, platform])
}

model Post {
  id         String   @id @default(uuid()) // post_id
  text       String   @db.LongText
  likeAmount Int      @default(0)
  hashtags   String? // egyszerűsített: tárolható CSV-ként vagy JSON-ként, igény szerint változtatható
  postedAt   DateTime @default(now())
  title      String   
  topic      String   

  user   User @relation(fields: [userId], references: [id])
  userId String

  comments Comment[]
  moderationLogs ModerationLog[]
}

model Comment {
  id          String   @id @default(uuid()) // comment_id
  text        String   @db.Text
  likeAmount  Int      @default(0)
  commentedAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id])
  userId String

  post   Post @relation(fields: [postId], references: [id])
  postId String

  // Likes tracking
  likes   CommentLike[]

  // önreferenciális kapcsolat (reply / previous comment)
  previousComment   Comment?  @relation("PreviousComment", fields: [previousCommentId], references: [id])
  previousCommentId String?
  replies           Comment[] @relation("PreviousComment")
  moderationLogs    ModerationLog[]
}

model Notification {
  id        String   @id @default(uuid()) // notification_id
  type      String
  message   String?  @db.Text
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Akihez tartozik a notification
  user   User @relation("UserNotifications", fields: [userId], references: [id])
  userId String

  // Opcionális: melyik user váltotta ki (triggered_by)
  triggeredBy   User? @relation("TriggeredNotifications", fields: [triggeredById], references: [id])
  triggeredById String?
}

enum ModerationStatus {
  PENDING
  RESOLVED
  IGNORED
}

model ModerationLog {
  id        String            @id @default(uuid())
  reason    String
  status    ModerationStatus  @default(PENDING)
  createdAt DateTime          @default(now())

  // The content that was flagged (optional relations)
  post   Post?   @relation(fields: [postId], references: [id])
  postId String?

  comment   Comment? @relation(fields: [commentId], references: [id])
  commentId String?

  // The user who created the content
  user   User   @relation(fields: [userId], references: [id])
  userId String
}

model CommentLike {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  comment   Comment  @relation(fields: [commentId], references: [id])
  commentId String

  @@unique([userId, commentId])
}
