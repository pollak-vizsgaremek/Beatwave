// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// Continue after the 5th point for setting up the db

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum SpotifyTimeRange {
  SHORT
  MEDIUM
  LONG
}

model User {
  id                String   @id @default(uuid()) // user_id
  email             String   @unique
  username          String   @unique
  passwordHash      String
  authTokenVersion  Int      @default(0)
  description       String?  @db.Text
  isPrivate         Boolean  @default(false)
  isBlocked         Boolean  @default(false)
  role              Role     @default(USER)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  spotifyTimeRange  SpotifyTimeRange @default(SHORT)

  // Relációk
  connectedApps          ConnectedApp[]
  posts                  Post[]
  comments               Comment[]
  commentLikes           CommentLike[]
  postLikes              PostLike[]
  notifications          Notification[] @relation("UserNotifications")
  triggeredNotifications Notification[] @relation("TriggeredNotifications")
  moderationLogs         ModerationLog[] @relation("UserLogs")
  performedModerations   ModerationLog[] @relation("ModeratorLogs")
  passwordResetTokens    PasswordResetToken[]
}

model ConnectedApp {
  id          String   @id @default(uuid()) // internal id
  platform     String
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  connectedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String

  @@unique([userId, platform])
}

model Post {
  id         String   @id @default(uuid()) // post_id
  text       String   @db.LongText
  likeAmount Int      @default(0)
  hashtags   String? // egyszerűsített: tárolható CSV-ként vagy JSON-ként, igény szerint változtatható
  postedAt   DateTime @default(now())
  title      String   
  topic      String   

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  comments Comment[]
  moderationLogs ModerationLog[]
  likes PostLike[]
}

model Comment {
  id          String   @id @default(uuid()) // comment_id
  text        String   @db.Text
  likeAmount  Int      @default(0)
  commentedAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  // Likes tracking
  likes   CommentLike[]

  // önreferenciális kapcsolat (reply / previous comment)
  previousComment   Comment?  @relation("PreviousComment", fields: [previousCommentId], references: [id] , onDelete: Cascade)
  previousCommentId String?
  replies           Comment[] @relation("PreviousComment")
  moderationLogs    ModerationLog[]
}

model Notification {
  id        String   @id @default(uuid()) // notification_id
  type      String
  message   String?  @db.Text
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Akihez tartozik a notification
  user   User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Opcionális: melyik user váltotta ki (triggered_by)
  triggeredBy   User? @relation("TriggeredNotifications", fields: [triggeredById], references: [id], onDelete: SetNull)
  triggeredById String?
}

enum ModerationStatus {
  DELETED
  NOTIFIED
  REPORTED
  DISMISSED
  BLOCKED
  ROLE_CHANGED
}

model ModerationLog {
  id        String            @id @default(uuid())
  status    ModerationStatus  @default(NOTIFIED)
  action    String            // What action was taken (DELETE_POST, DELETE_COMMENT, etc.)
  details   String            // Additional details about the action
  createdAt DateTime          @default(now())

  // The admin/moderator who performed the action
  moderator   User   @relation("ModeratorLogs", fields: [moderatorId], references: [id], onDelete: Cascade)
  moderatorId String

  // The user who created the content
  user   User   @relation("UserLogs", fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // The content that was moderated (optional relations)
  post   Post?   @relation(fields: [postId], references: [id], onDelete: SetNull)
  postId String?

  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)
  commentId String?
}

model CommentLike {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String

  @@unique([userId, commentId])
}

model PostLike {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String

  @@unique([userId, postId])
}

model RevokedToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}
